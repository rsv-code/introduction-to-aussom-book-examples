/**
 * string_utils - small string helpers.
 */
class StringUtils {
    /**
     * Reverses the characters of a string.
     * @p S the string to reverse.
     * @r string - the reversed string.
     */
    public reverse(S) {
        out = "";
        for (i = #S - 1; i >= 0; i--) { out = out + S.charAt(i); }
        return out;
    }
}
